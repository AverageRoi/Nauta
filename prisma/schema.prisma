generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model cords {
    id Int @id @default(autoincrement())
    guildId String
    interaction_user String
    alias String
    x_coordinates String 
    y_coordinates String?
    z_coordinates String 
    dimension String 
}

model derole {
  id Int @id @default(autoincrement())
  guildId String @unique
  DELETOR String
}

model regrole {
  id Int @id @default(autoincrement())
  guildId String @unique
  REGISTRATOR String
}
